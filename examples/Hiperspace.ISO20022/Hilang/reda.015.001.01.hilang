@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:reda.015.001.01"), ValidationCheck, AnyKey
value ISO20022.Reda015001.PartyIdentification120Choice
{
    @XmlElement NmAndAdr           : ISO20022.Reda015001.NameAndAddress5,
    @XmlElement PrtryId            : ISO20022.Reda015001.GenericIdentification36,
    @XmlElement AnyBIC             : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(NmAndAdr), 
        validElement(PrtryId), 
        validPattern ("AnyBIC", AnyBIC, "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}"), 
        validChoice (NmAndAdr, PrtryId, AnyBIC))
];

