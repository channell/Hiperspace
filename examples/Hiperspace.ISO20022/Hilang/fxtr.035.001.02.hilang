@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:fxtr.035.001.02"), ValidationCheck
value ISO20022.Fxtr035001.Trade10
{
    @XmlElement AssoctdTradRef     : List<String>,
    @XmlElement DltaInd            : String,
    @XmlElement OptnInd            : String,
    @XmlElement FxgDt              : DateTime,
    @XmlElement FxgCcy             : String,
    @XmlElement SctyId             : ISO20022.Fxtr035001.SecurityIdentification18,
    @XmlElement RskAmt             : ISO20022.Fxtr035001.ActiveCurrencyAndAmount,
    @XmlElement ValDt              : DateTime,
    @XmlElement ClctdCtrPtyCcyLastQty : ISO20022.Fxtr035001.ActiveCurrencyAndAmount,
    @XmlElement FwdPts             : Decimal,
    @XmlElement ValtnRate          : ISO20022.Fxtr035001.AgreedRate3,
    @XmlElement SttlmDt            : DateTime,
    @XmlElement SttlmTp            : String,
    @XmlElement LastQty            : ISO20022.Fxtr035001.ActiveCurrencyAndAmount,
