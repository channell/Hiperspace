@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:fxtr.035.001.02"), ValidationCheck
value ISO20022.Fxtr035001.Trade9
{
    @XmlElement AssoctdTradRef     : List<String>,
    @XmlElement PdctId             : ISO20022.Fxtr035001.SecurityIdentification38Choice,
    @XmlElement SwpLeg             : List<ISO20022.Fxtr035001.InstrumentLeg7>,
    @XmlElement FXDtls             : ISO20022.Fxtr035001.Trade10,
    @XmlElement PlcOfConf          : String,
    @XmlElement Symb               : String,
    @XmlElement ClrMtd             : String,
    @XmlElement TradgMd            : String,
    @XmlElement TradgMtd           : String,
    @XmlElement SttlmCcy           : String,
    @XmlElement TradgCcy           : String,
    @XmlElement FXTradPdct         : String,
    @XmlElement TradDt             : DateTime,
    @XmlElement TradId             : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(PdctId), 
        validList ("SwpLeg", SwpLeg), 
        validElement(SwpLeg), 
        validElement(FXDtls), 
        validPattern ("PlcOfConf", PlcOfConf, "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}"), 
        validPattern ("SttlmCcy", SttlmCcy, "[A-Z]{3,3}"), 
        validPattern ("TradgCcy", TradgCcy, "[A-Z]{3,3}"))
];

