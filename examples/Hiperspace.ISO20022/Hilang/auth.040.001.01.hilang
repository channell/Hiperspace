}
[
    @XmlIgnore, JsonIgnore Validation = ""
];

@XmlNameSpace("urn:iso:std:iso:20022:tech:xsd:auth.040.001.01")
enum ISO20022.Auth040001.TradingVenue2Code
{
    @XmlEnum ("CTPS") CTPS          #1,
    @XmlEnum ("APPA") APPA          #2,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.040.001.01"), ValidationCheck, AnyKey
value ISO20022.Auth040001.TradingVenueIdentification1Choice
{
    @XmlElement Othr               : ISO20022.Auth040001.TradingVenueIdentification2,
    @XmlElement NtlCmptntAuthrty   : String,
    @XmlElement MktIdCd            : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Othr), 
        validPattern ("NtlCmptntAuthrty", NtlCmptntAuthrty, "[A-Z]{2,2}"), 
        validPattern ("MktIdCd", MktIdCd, "[A-Z0-9]{4,4}"), 
        validChoice (Othr, NtlCmptntAuthrty, MktIdCd))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.040.001.01"), ValidationCheck
value ISO20022.Auth040001.TradingVenueIdentification2
{
    @XmlElement Tp                 : String,
    @XmlElement Id                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = ""
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.040.001.01"), ValidationCheck
value ISO20022.Auth040001.TransparencyDataReport13
{
    @XmlElement TxsExctdExclgPstTradLrgInScaleWvr : ISO20022.Auth040001.NumberAndVolume2,
    @XmlElement TxsExctdExclgPreTradWvr : ISO20022.Auth040001.NumberAndVolume2,
    @XmlElement TxsExctd           : ISO20022.Auth040001.NumberAndVolume2,
    @XmlElement Sspnsn             : String,
    @XmlElement TradgVn            : String,
    @XmlElement RptgDt             : DateTime,
    @XmlElement Id                 : String,
    @XmlElement TechRcrdId         : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(TxsExctdExclgPstTradLrgInScaleWvr), 
        validElement(TxsExctdExclgPreTradWvr), 
        validElement(TxsExctd), 
        validPattern ("TradgVn", TradgVn, "[A-Z0-9]{4,4}"), 
        validPattern ("Id", Id, "[A-Z]{2,2}[A-Z0-9]{9,9}[0-9]{1,1}"))
];
