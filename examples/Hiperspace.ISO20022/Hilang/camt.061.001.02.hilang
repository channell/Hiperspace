%json;
%xml;
%markdown;


@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
value ISO20022.Camt061001.ActiveOrHistoricCurrencyAndAmount
{
    @XmlElement Value              : Decimal,
    @XmlAttribute Ccy              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validRequired ("Value", Value), 
        validRequired ("Ccy", Ccy), 
        validPattern ("Ccy", Ccy, "[A-Z]{3,3}"))
];

@XmlNameSpace("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02")
enum ISO20022.Camt061001.AddressType2Code
{
    @XmlEnum ("DLVY") DLVY          #1,
    @XmlEnum ("MLTO") MLTO          #2,
    @XmlEnum ("BIZZ") BIZZ          #3,
    @XmlEnum ("HOME") HOME          #4,
    @XmlEnum ("PBOX") PBOX          #5,
    @XmlEnum ("ADDR") ADDR          #6,
};
@XmlNameSpace("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02")
enum ISO20022.Camt061001.CallIn1Code
{
    @XmlEnum ("CFCC") CFCC          #1,
    @XmlEnum ("CFST") CFST          #2,
    @XmlEnum ("CFAV") CFAV          #3,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck, AnyKey
value ISO20022.Camt061001.ClearingSystemIdentification2Choice
{
    @XmlElement Prtry              : String,
    @XmlElement Cd                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (validChoice (Prtry, Cd))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
type ISO20022.Camt061001.Document
{
}
[
    @XmlElement PayInCall          : ISO20022.Camt061001.PayInCallV02,
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(PayInCall))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
value ISO20022.Camt061001.NameAndAddress8
{
    @XmlElement AltrntvIdr         : List<String>,
    @XmlElement Adr                : ISO20022.Camt061001.PostalAddress1,
    @XmlElement Nm                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validListMax ("AltrntvIdr", AltrntvIdr, 10), 
        validElement(Adr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
value ISO20022.Camt061001.PartyIdentification44
{
    @XmlElement AltrntvIdr         : List<String>,
    @XmlElement AnyBIC             : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validListMax ("AltrntvIdr", AltrntvIdr, 10), 
        validPattern ("AnyBIC", AnyBIC, "[A-Z]{6,6}[A-Z2-9][A-NP-Z0-9]([A-Z0-9]{3,3}){0,1}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
value ISO20022.Camt061001.PartyIdentification59
{
    @XmlElement LglNttyIdr         : String,
    @XmlElement ClrSysId           : ISO20022.Camt061001.ClearingSystemIdentification2Choice,
    @XmlElement Adr                : String,
    @XmlElement AcctNb             : String,
    @XmlElement AnyBIC             : ISO20022.Camt061001.PartyIdentification44,
    @XmlElement PtyNm              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("LglNttyIdr", LglNttyIdr, "[A-Z0-9]{18,18}[0-9]{2,2}"), 
        validElement(ClrSysId), 
        validElement(AnyBIC))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck, AnyKey
value ISO20022.Camt061001.PartyIdentification73Choice
{
    @XmlElement PtyId              : ISO20022.Camt061001.PartyIdentification59,
    @XmlElement AnyBIC             : ISO20022.Camt061001.PartyIdentification44,
    @XmlElement NmAndAdr           : ISO20022.Camt061001.NameAndAddress8,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(PtyId), 
        validElement(AnyBIC), 
        validElement(NmAndAdr), 
        validChoice (PtyId, AnyBIC, NmAndAdr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
value ISO20022.Camt061001.PayInCallItem
{
    @XmlElement Amt                : ISO20022.Camt061001.ActiveOrHistoricCurrencyAndAmount,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Amt))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
aspect ISO20022.Camt061001.PayInCallV02
{
    @XmlElement SplmtryData        : List<ISO20022.Camt061001.SupplementaryData1>,
    @XmlElement SttlmSsnIdr        : String,
    @XmlElement RptData            : ISO20022.Camt061001.ReportData5,
    @XmlElement PtyId              : ISO20022.Camt061001.PartyIdentification73Choice,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validPattern ("SttlmSsnIdr", SttlmSsnIdr, "[a-zA-Z0-9]{4}"), 
        validElement(RptData), 
        validElement(PtyId))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
value ISO20022.Camt061001.PostalAddress1
{
    @XmlElement Ctry               : String,
    @XmlElement CtrySubDvsn        : String,
    @XmlElement TwnNm              : String,
    @XmlElement PstCd              : String,
    @XmlElement BldgNb             : String,
    @XmlElement StrtNm             : String,
    @XmlElement AdrLine            : List<String>,
    @XmlElement AdrTp              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("Ctry", Ctry, "[A-Z]{2,2}"), 
        validListMax ("AdrLine", AdrLine, 5))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.061.001.02"), ValidationCheck
value ISO20022.Camt061001.ReportData5
{
    @XmlElement AcctVal            : ISO20022.Camt061001.Value,
    @XmlElement SttlmSsnIdr        : String,
    @XmlElement PayInCallAmt       : List<ISO20022.Camt061001.PayInCallItem>,
    @XmlElement Tp                 : String,
    @XmlElement DtAndTmStmp        : DateTime,
    @XmlElement ValDt              : DateTime,
    @XmlElement MsgId              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(AcctVal), 
        validPattern ("SttlmSsnIdr", SttlmSsnIdr, "[a-zA-Z0-9]{4}"), 
        validList ("PayInCallAmt", PayInCallAmt), 
        validElement(PayInCallAmt))
];

