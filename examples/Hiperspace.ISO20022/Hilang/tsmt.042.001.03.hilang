@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.042.001.03"), ValidationCheck
value ISO20022.Tsmt042001.ReportSpecification4
{
    @XmlElement PdgReqForActn      : List<ISO20022.Tsmt042001.PendingActivity1>,
    @XmlElement CrspdtCtry         : List<String>,
    @XmlElement SellrCtry          : List<String>,
    @XmlElement BuyrCtry           : List<String>,
    @XmlElement Sellr              : List<ISO20022.Tsmt042001.PartyIdentification28>,
    @XmlElement Buyr               : List<ISO20022.Tsmt042001.PartyIdentification28>,
    @XmlElement OblgrBk            : List<ISO20022.Tsmt042001.BICIdentification1>,
    @XmlElement SubmitgBk          : List<ISO20022.Tsmt042001.BICIdentification1>,
    @XmlElement Crspdt             : List<ISO20022.Tsmt042001.BICIdentification1>,
    @XmlElement NttiesToBeRptd     : List<ISO20022.Tsmt042001.BICIdentification1>,
    @XmlElement SubmitrTxRef       : List<String>,
    @XmlElement TxSts              : List<ISO20022.Tsmt042001.TransactionStatus4>,
    @XmlElement TxId               : List<String>,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("PdgReqForActn", PdgReqForActn), 
        validElement(PdgReqForActn), 
        validPattern ("CrspdtCtry", CrspdtCtry, "[A-Z]{2,2}"), 
        validPattern ("SellrCtry", SellrCtry, "[A-Z]{2,2}"), 
        validPattern ("BuyrCtry", BuyrCtry, "[A-Z]{2,2}"), 
        validList ("Sellr", Sellr), 
        validElement(Sellr), 
        validList ("Buyr", Buyr), 
        validElement(Buyr), 
        validList ("OblgrBk", OblgrBk), 
        validElement(OblgrBk), 
        validList ("SubmitgBk", SubmitgBk), 
        validElement(SubmitgBk), 
        validList ("Crspdt", Crspdt), 
        validElement(Crspdt), 
        validList ("NttiesToBeRptd", NttiesToBeRptd), 
        validElement(NttiesToBeRptd), 
        validList ("TxSts", TxSts), 
        validElement(TxSts))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.042.001.03"), ValidationCheck
aspect ISO20022.Tsmt042001.TransactionReportRequestV03
{
    @XmlElement RptSpcfctn         : ISO20022.Tsmt042001.ReportSpecification4,
    @XmlElement ReqId              : ISO20022.Tsmt042001.MessageIdentification1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(RptSpcfctn), 
        validElement(ReqId))
];

