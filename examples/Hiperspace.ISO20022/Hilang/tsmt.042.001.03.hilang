@XmlNameSpace("urn:iso:std:iso:20022:tech:xsd:tsmt.042.001.03")
enum ISO20022.Tsmt042001.Action1Code
{
    @XmlEnum ("ARBA") ARBA          #1,
    @XmlEnum ("SBDS") SBDS          #2,
    @XmlEnum ("UPDT") UPDT          #3,
    @XmlEnum ("WAIT") WAIT          #4,
    @XmlEnum ("ARES") ARES          #5,
    @XmlEnum ("ARCS") ARCS          #6,
    @XmlEnum ("ARDM") ARDM          #7,
    @XmlEnum ("RSBS") RSBS          #8,
    @XmlEnum ("RSTW") RSTW          #9,
    @XmlEnum ("SBTW") SBTW          #10,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.042.001.03"), ValidationCheck
value ISO20022.Tsmt042001.BICIdentification1
{
    @XmlElement BIC                : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("BIC", BIC, "[A-Z]{6,6}[A-Z2-9][A-NP-Z0-9]([A-Z0-9]{3,3}){0,1}"))
];

