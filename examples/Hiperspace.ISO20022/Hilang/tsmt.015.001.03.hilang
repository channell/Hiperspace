    @XmlEnum ("RARQ") RARQ          #5,
    @XmlEnum ("AMRQ") AMRQ          #6,
    @XmlEnum ("COMP") COMP          #7,
    @XmlEnum ("ACTV") ACTV          #8,
    @XmlEnum ("ESTD") ESTD          #9,
    @XmlEnum ("PMTC") PMTC          #10,
    @XmlEnum ("CLSD") CLSD          #11,
    @XmlEnum ("PROP") PROP          #12,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.015.001.03"), ValidationCheck, AnyKey
value ISO20022.Tsmt015001.ComparisonResult2
{
    @XmlElement Addtn              : ISO20022.Tsmt015001.Addition2,
    @XmlElement Deltn              : ISO20022.Tsmt015001.Deletion2,
    @XmlElement Rplcmnt            : ISO20022.Tsmt015001.Replacement2,
    @XmlElement ElmtNm             : String,
    @XmlElement ElmtPth            : String,
    @XmlElement ElmtSeqNb          : Decimal,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Addtn), 
        validElement(Deltn), 
        validElement(Rplcmnt), 
        validChoice (Addtn, Deltn, Rplcmnt, ElmtNm, ElmtPth, ElmtSeqNb))
];

