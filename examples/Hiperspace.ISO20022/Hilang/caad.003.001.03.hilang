aspect ISO20022.Caad003001.BatchTransferInitiationV03
{
    @XmlElement SctyTrlr           : ISO20022.Caad003001.ContentInformationType41,
    @XmlElement SplmtryData        : List<ISO20022.Caad003001.SupplementaryData1>,
    @XmlElement PrtctdData         : List<ISO20022.Caad003001.ProtectedData2>,
    @XmlElement AddtlData          : List<ISO20022.Caad003001.AdditionalData2>,
    @XmlElement PrcgRslt           : ISO20022.Caad003001.ProcessingResult26,
    @XmlElement OrgnlRspnCd        : String,
    @XmlElement Rcncltn            : ISO20022.Caad003001.Reconciliation4,
    @XmlElement SttlmSvc           : ISO20022.Caad003001.SettlementService6,
    @XmlElement Jursdctn           : ISO20022.Caad003001.Jurisdiction2,
    @XmlElement Rcrd               : List<ISO20022.Caad003001.Record3>,
    @XmlElement AgtData            : List<ISO20022.Caad003001.AdditionalInformation21>,
    @XmlElement ClrCtrlTtls        : ISO20022.Caad003001.ClearingControlTotals3,
    @XmlElement ClrBtchData        : List<ISO20022.Caad003001.ClearingBatchData3>,
    @XmlElement LifeCyclId         : String,
    @XmlElement RtrvlRefNb         : String,
    @XmlElement TrnsmssnDtTm       : DateTime,
    @XmlElement SysTracAudtNb      : String,
    @XmlElement Prgrmm             : List<ISO20022.Caad003001.ProgrammeMode5>,
    @XmlElement Dstn               : ISO20022.Caad003001.PartyIdentification286,
    @XmlElement Orgtr              : ISO20022.Caad003001.PartyIdentification286,
    @XmlElement ReqAck             : String,
    @XmlElement BtchChcksm         : String,
    @XmlElement NbOfMsgs           : Decimal,
    @XmlElement OrgnlBtchId        : String,
    @XmlElement BtchId             : String,
    @XmlElement Hdr                : ISO20022.Caad003001.Header71,
}
[
