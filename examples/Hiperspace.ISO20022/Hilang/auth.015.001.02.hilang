%json;
%xml;
%markdown;


@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.015.001.02"), ValidationCheck
value ISO20022.Auth015001.ActiveCurrencyAndAmount
{
    @XmlElement Value              : Decimal,
    @XmlAttribute Ccy              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validRequired ("Value", Value), 
        validRequired ("Ccy", Ccy), 
        validPattern ("Ccy", Ccy, "[A-Z]{3,3}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.015.001.02"), ValidationCheck, AnyKey
value ISO20022.Auth015001.CounterpartyIdentification3Choice
{
    @XmlElement NmAndLctn          : ISO20022.Auth015001.NameAndLocation1,
    @XmlElement SctrAndLctn        : ISO20022.Auth015001.SectorAndLocation1,
    @XmlElement LEI                : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(NmAndLctn), 
        validElement(SctrAndLctn), 
        validPattern ("LEI", LEI, "[A-Z0-9]{18,18}[0-9]{2,2}"), 
        validChoice (NmAndLctn, SctrAndLctn, LEI))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.015.001.02"), ValidationCheck, AnyKey
value ISO20022.Auth015001.DateAndDateTimeChoice
{
    @XmlElement DtTm               : DateTime,
    @XmlElement Dt                 : DateTime,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (validChoice (DtTm, Dt))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.015.001.02"), ValidationCheck
value ISO20022.Auth015001.DateTimePeriod1
{
    @XmlElement ToDtTm             : DateTime,
    @XmlElement FrDtTm             : DateTime,
}
[
    @XmlIgnore, JsonIgnore Validation = ""
];

