@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.015.001.02"), ValidationCheck
value ISO20022.Auth015001.MoneyMarketReportHeader1
{
    @XmlElement RefPrd             : ISO20022.Auth015001.DateTimePeriod1,
