        validElement(MnyMktOvrnghtIndxSwpsSttstclRpt))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.015.001.02"), ValidationCheck
aspect ISO20022.Auth015001.MoneyMarketOvernightIndexSwapsStatisticalReportV02
{
    @XmlElement SplmtryData        : List<ISO20022.Auth015001.SupplementaryData1>,
    @XmlElement OvrnghtIndxSwpsRpt : ISO20022.Auth015001.OvernightIndexSwap4Choice,
