@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.044.001.02"), ValidationCheck, AnyKey
value ISO20022.Tsmt044001.AccountIdentification4Choice
{
    @XmlElement Othr               : ISO20022.Tsmt044001.GenericAccountIdentification1,
    @XmlElement IBAN               : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Othr), 
        validPattern ("IBAN", IBAN, "[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}"), 
        validChoice (Othr, IBAN))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.044.001.02"), ValidationCheck, AnyKey
value ISO20022.Tsmt044001.AccountSchemeName1Choice
{
