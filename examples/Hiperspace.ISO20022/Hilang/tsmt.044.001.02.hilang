enum ISO20022.Tsmt044001.AdjustmentDirection1Code
{
    @XmlEnum ("SUBS") SUBS          #1,
    @XmlEnum ("ADDD") ADDD          #2,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.044.001.02"), ValidationCheck, AnyKey
value ISO20022.Tsmt044001.AdjustmentType1Choice
