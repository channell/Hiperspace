@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.059.001.02"), ValidationCheck
value ISO20022.Auth059001.IncomeStatement2
{
    @XmlElement PstTaxPrftOrLoss   : ISO20022.Auth059001.AmountAndDirection102,
    @XmlElement PreTaxPrftOrLoss   : ISO20022.Auth059001.AmountAndDirection102,
    @XmlElement NonOprgExpnss      : ISO20022.Auth059001.ActiveCurrencyAndAmount,
    @XmlElement OthrNonOprgRvn     : ISO20022.Auth059001.ActiveCurrencyAndAmount,
    @XmlElement NetIntrstIncm      : ISO20022.Auth059001.ActiveCurrencyAndAmount,
    @XmlElement OprgPrftOrLoss     : ISO20022.Auth059001.AmountAndDirection102,
    @XmlElement OprgExpnss         : ISO20022.Auth059001.ActiveCurrencyAndAmount,
    @XmlElement OthrOprgRvn        : ISO20022.Auth059001.ActiveCurrencyAndAmount,
    @XmlElement ClrMmbFee          : List<ISO20022.Auth059001.ClearingMemberFee1>,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(PstTaxPrftOrLoss), 
        validElement(PreTaxPrftOrLoss), 
        validElement(NonOprgExpnss), 
        validElement(OthrNonOprgRvn), 
        validElement(NetIntrstIncm), 
        validElement(OprgPrftOrLoss), 
        validElement(OprgExpnss), 
        validElement(OthrOprgRvn), 
        validRequired ("ClrMmbFee", ClrMmbFee), 
        validList ("ClrMmbFee", ClrMmbFee), 
        validElement(ClrMmbFee))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.059.001.02"), ValidationCheck, AnyKey
value ISO20022.Auth059001.PartyIdentification118Choice
{
    @XmlElement Prtry              : ISO20022.Auth059001.GenericIdentification168,
    @XmlElement LEI                : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Prtry), 
        validPattern ("LEI", LEI, "[A-Z0-9]{18,18}[0-9]{2,2}"), 
        validChoice (Prtry, LEI))
];

