@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.059.001.02"), ValidationCheck
value ISO20022.Auth059001.ActiveCurrencyAndAmount
{
    @XmlElement Value              : Decimal,
    @XmlAttribute Ccy              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validRequired ("Value", Value), 
        validRequired ("Ccy", Ccy), 
        validPattern ("Ccy", Ccy, "[A-Z]{3,3}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.059.001.02"), ValidationCheck
value ISO20022.Auth059001.AmountAndDirection102
{
    @XmlElement Sgn                : String,
    @XmlElement Amt                : ISO20022.Auth059001.ActiveCurrencyAndAmount,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Amt))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.059.001.02"), ValidationCheck
aspect ISO20022.Auth059001.CCPIncomeStatementAndCapitalAdequacyReportV02
{
    @XmlElement SplmtryData        : List<ISO20022.Auth059001.SupplementaryData1>,
    @XmlElement HpthtclCptlMeasr   : List<ISO20022.Auth059001.HypotheticalCapitalMeasure1>,
    @XmlElement LqdFinRsrcs        : ISO20022.Auth059001.ActiveCurrencyAndAmount,
    @XmlElement TtlCptl            : ISO20022.Auth059001.ActiveCurrencyAndAmount,
    @XmlElement CptlRqrmnts        : ISO20022.Auth059001.CapitalRequirement1,
    @XmlElement IncmStmt           : ISO20022.Auth059001.IncomeStatement2,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validRequired ("HpthtclCptlMeasr", HpthtclCptlMeasr), 
        validList ("HpthtclCptlMeasr", HpthtclCptlMeasr), 
        validElement(HpthtclCptlMeasr), 
        validElement(LqdFinRsrcs), 
        validElement(TtlCptl), 
        validElement(CptlRqrmnts), 
        validElement(IncmStmt))
];

