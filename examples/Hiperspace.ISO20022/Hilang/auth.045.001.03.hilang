@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.045.001.03"), ValidationCheck
aspect ISO20022.Auth045001.FinancialInstrumentReportingNonEquityTradingActivityResultV03
{
    @XmlElement SplmtryData        : List<ISO20022.Auth045001.SupplementaryData1>,
    @XmlElement NonEqtyTrnsprncyData : List<ISO20022.Auth045001.TransparencyDataReport20>,
    @XmlElement RptHdr             : ISO20022.Auth045001.SecuritiesMarketReportHeader1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validRequired ("NonEqtyTrnsprncyData", NonEqtyTrnsprncyData), 
        validList ("NonEqtyTrnsprncyData", NonEqtyTrnsprncyData), 
        validElement(NonEqtyTrnsprncyData), 
        validElement(RptHdr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.045.001.03"), ValidationCheck
value ISO20022.Auth045001.InstrumentAndSubClassIdentification2
{
    @XmlElement FinInstrmClssfctn  : String,
    @XmlElement DerivSubClss       : ISO20022.Auth045001.NonEquitySubClass1,
    @XmlElement ISIN               : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(DerivSubClss), 
        validPattern ("ISIN", ISIN, "[A-Z]{2,2}[A-Z0-9]{9,9}[0-9]{1,1}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.045.001.03"), ValidationCheck, AnyKey
value ISO20022.Auth045001.InstrumentOrSubClassIdentification2Choice
{
    @XmlElement AsstClssAndSubClss : ISO20022.Auth045001.AssetClassAndSubClassIdentification2,
    @XmlElement ISINAndSubClss     : ISO20022.Auth045001.InstrumentAndSubClassIdentification2,
}
[
