@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.045.001.02"), ValidationCheck
aspect ISO20022.Tsmt045001.ForwardIntentToPayNotificationV02
{
    @XmlElement ReqForActn         : ISO20022.Tsmt045001.PendingActivity2,
    @XmlElement InttToPay          : ISO20022.Tsmt045001.IntentToPay2,
    @XmlElement SellrBk            : ISO20022.Tsmt045001.BICIdentification1,
    @XmlElement BuyrBk             : ISO20022.Tsmt045001.BICIdentification1,
    @XmlElement UsrTxRef           : List<ISO20022.Tsmt045001.DocumentIdentification5>,
    @XmlElement TxSts              : ISO20022.Tsmt045001.TransactionStatus4,
    @XmlElement EstblishdBaselnId  : ISO20022.Tsmt045001.DocumentIdentification3,
    @XmlElement TxId               : ISO20022.Tsmt045001.SimpleIdentificationInformation,
    @XmlElement NtfctnId           : ISO20022.Tsmt045001.MessageIdentification1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(ReqForActn), 
        validElement(InttToPay), 
        validElement(SellrBk), 
        validElement(BuyrBk), 
        validList ("UsrTxRef", UsrTxRef), 
        validListMax ("UsrTxRef", UsrTxRef, 2), 
        validElement(UsrTxRef), 
        validElement(TxSts), 
        validElement(EstblishdBaselnId), 
        validElement(TxId), 
        validElement(NtfctnId))
];

