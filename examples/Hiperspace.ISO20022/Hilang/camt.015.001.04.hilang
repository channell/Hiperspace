@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.015.001.04"), ValidationCheck
value ISO20022.Camt015001.Member6
{
    @XmlElement ComAdr             : ISO20022.Camt015001.CommunicationAddress8,
    @XmlElement CtctRef            : List<ISO20022.Camt015001.ContactIdentificationAndAddress1>,
    @XmlElement MmbRtrAdr          : List<ISO20022.Camt015001.MemberIdentification3Choice>,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(ComAdr), 
        validList ("CtctRef", CtctRef), 
        validElement(CtctRef), 
        validList ("MmbRtrAdr", MmbRtrAdr), 
        validElement(MmbRtrAdr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.015.001.04"), ValidationCheck, AnyKey
value ISO20022.Camt015001.MemberIdentification3Choice
{
    @XmlElement Othr               : ISO20022.Camt015001.GenericFinancialIdentification1,
    @XmlElement ClrSysMmbId        : ISO20022.Camt015001.ClearingSystemMemberIdentification2,
    @XmlElement BICFI              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Othr), 
        validElement(ClrSysMmbId), 
        validPattern ("BICFI", BICFI, "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}"), 
        validChoice (Othr, ClrSysMmbId, BICFI))
];

