    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(NetRpt))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck
value ISO20022.Camt088001.NameAndAddress8
{
    @XmlElement AltrntvIdr         : List<String>,
    @XmlElement Adr                : ISO20022.Camt088001.PostalAddress1,
    @XmlElement Nm                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validListMax ("AltrntvIdr", AltrntvIdr, 10), 
        validElement(Adr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck
value ISO20022.Camt088001.NetObligation3
{
    @XmlElement TxsNb              : String,
    @XmlElement PmtClrCentr        : String,
    @XmlElement CtrPtySttlmInstrs  : ISO20022.Camt088001.SettlementParties120,
    @XmlElement NetSvcCtrPtyId     : ISO20022.Camt088001.PartyIdentification242Choice,
    @XmlElement CtrPtyNetgId       : ISO20022.Camt088001.NettingIdentification2Choice,
    @XmlElement OblgtnDrctn        : String,
    @XmlElement PtcptNetgId        : ISO20022.Camt088001.NettingIdentification2Choice,
    @XmlElement Amt                : ISO20022.Camt088001.ActiveCurrencyAndAmount,
    @XmlElement OblgtnId           : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("TxsNb", TxsNb, "[0-9]{1,10}"), 
        validPattern ("PmtClrCentr", PmtClrCentr, "[A-Z]{2,2}"), 
        validElement(CtrPtySttlmInstrs), 
        validElement(NetSvcCtrPtyId), 
        validElement(CtrPtyNetgId), 
        validElement(PtcptNetgId), 
        validElement(Amt))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck
value ISO20022.Camt088001.NetReportData2
{
    @XmlElement MsgPgntn           : ISO20022.Camt088001.Pagination1,
    @XmlElement NetSvcTp           : String,
    @XmlElement NetRptSvcr         : ISO20022.Camt088001.PartyIdentification242Choice,
    @XmlElement RptTp              : String,
    @XmlElement ValDt              : DateTime,
    @XmlElement RptDt              : DateTime,
    @XmlElement NetgCutOffTm       : DateTime,
    @XmlElement CreDtTm            : DateTime,
    @XmlElement MsgId              : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(MsgPgntn), 
        validElement(NetRptSvcr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck
aspect ISO20022.Camt088001.NetReportV03
{
    @XmlElement SplmtryData        : List<ISO20022.Camt088001.SupplementaryData1>,
    @XmlElement NetOblgtn          : List<ISO20022.Camt088001.NetObligation3>,
    @XmlElement NetSvcCtrPtyId     : ISO20022.Camt088001.PartyIdentification242Choice,
    @XmlElement NetSvcPtcptId      : ISO20022.Camt088001.PartyIdentification242Choice,
    @XmlElement NetRptData         : ISO20022.Camt088001.NetReportData2,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validRequired ("NetOblgtn", NetOblgtn), 
        validList ("NetOblgtn", NetOblgtn), 
        validElement(NetOblgtn), 
        validElement(NetSvcCtrPtyId), 
        validElement(NetSvcPtcptId), 
        validElement(NetRptData))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck, AnyKey
value ISO20022.Camt088001.NettingIdentification2Choice
