@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck, AnyKey
value ISO20022.Camt088001.PartyIdentification242Choice
{
    @XmlElement PtyId              : ISO20022.Camt088001.PartyIdentification266,
    @XmlElement AnyBIC             : ISO20022.Camt088001.PartyIdentification265,
    @XmlElement NmAndAdr           : ISO20022.Camt088001.NameAndAddress8,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(PtyId), 
        validElement(AnyBIC), 
        validElement(NmAndAdr), 
        validChoice (PtyId, AnyBIC, NmAndAdr))
