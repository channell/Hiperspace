[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("LglNttyIdr", LglNttyIdr, "[A-Z0-9]{18,18}[0-9]{2,2}"), 
        validElement(ClrSysId), 
        validElement(AnyBIC))
];

