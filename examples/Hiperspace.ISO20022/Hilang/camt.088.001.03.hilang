@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck
value ISO20022.Camt088001.PartyIdentification265
{
    @XmlElement AltrntvIdr         : List<String>,
    @XmlElement AnyBIC             : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validListMax ("AltrntvIdr", AltrntvIdr, 10), 
        validPattern ("AnyBIC", AnyBIC, "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:camt.088.001.03"), ValidationCheck
value ISO20022.Camt088001.PartyIdentification266
{
    @XmlElement LglNttyIdr         : String,
