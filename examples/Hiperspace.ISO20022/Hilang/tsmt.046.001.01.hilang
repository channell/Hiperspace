    @XmlElement Id                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = ""
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.046.001.01"), ValidationCheck
aspect ISO20022.Tsmt046001.IntentToPayReportV01
{
    @XmlElement RptdItms           : List<ISO20022.Tsmt046001.ReportLine1>,
    @XmlElement RptId              : ISO20022.Tsmt046001.MessageIdentification1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("RptdItms", RptdItms), 
        validElement(RptdItms), 
        validElement(RptId))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.046.001.01"), ValidationCheck
value ISO20022.Tsmt046001.MessageIdentification1
