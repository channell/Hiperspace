@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.008.001.03"), ValidationCheck, AnyKey
value ISO20022.Tsmt008001.RejectionReason1Choice
{
    @XmlElement RjctdElmt          : List<ISO20022.Tsmt008001.RejectedElement1>,
    @XmlElement GblRjctnRsn        : ISO20022.Tsmt008001.Reason2,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
