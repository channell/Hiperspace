}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("ValDtOffset", ValDtOffset, "0|-1|-2"), 
        validPattern ("Ccy", Ccy, "[A-Z]{3,3}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:reda.060.001.02"), ValidationCheck
type ISO20022.Reda060001.Document
