%json;
%xml;
%markdown;


@XmlNameSpace("urn:iso:std:iso:20022:tech:xsd:auth.038.001.01")
enum ISO20022.Auth038001.AddressType2Code
{
    @XmlEnum ("DLVY") DLVY          #1,
    @XmlEnum ("MLTO") MLTO          #2,
    @XmlEnum ("BIZZ") BIZZ          #3,
    @XmlEnum ("HOME") HOME          #4,
    @XmlEnum ("PBOX") PBOX          #5,
    @XmlEnum ("ADDR") ADDR          #6,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.038.001.01"), ValidationCheck
value ISO20022.Auth038001.ContactDetails2
{
    @XmlElement Othr               : String,
    @XmlElement EmailAdr           : String,
    @XmlElement FaxNb              : String,
    @XmlElement MobNb              : String,
    @XmlElement PhneNb             : String,
    @XmlElement Nm                 : String,
    @XmlElement NmPrfx             : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("FaxNb", FaxNb, "\+[0-9]{1,3}-[0-9()+\-]{1,30}"), 
        validPattern ("MobNb", MobNb, "\+[0-9]{1,3}-[0-9()+\-]{1,30}"), 
        validPattern ("PhneNb", PhneNb, "\+[0-9]{1,3}-[0-9()+\-]{1,30}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.038.001.01"), ValidationCheck
type ISO20022.Auth038001.Document
{
}
[
    @XmlElement InvcTaxRptStsAdvc  : ISO20022.Auth038001.InvoiceTaxReportStatusAdviceV01,
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(InvcTaxRptStsAdvc))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.038.001.01"), ValidationCheck
value ISO20022.Auth038001.GenericValidationRuleIdentification1
{
    @XmlElement Issr               : String,
    @XmlElement SchmeNm            : ISO20022.Auth038001.ValidationRuleSchemeName1Choice,
    @XmlElement Desc               : String,
    @XmlElement Id                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(SchmeNm))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.038.001.01"), ValidationCheck
aspect ISO20022.Auth038001.InvoiceTaxReportStatusAdviceV01
{
    @XmlElement SplmtryData        : List<ISO20022.Auth038001.SupplementaryData1>,
    @XmlElement TxSts              : List<ISO20022.Auth038001.InvoiceTaxReportTransactionStatus1>,
    @XmlElement StsRptHdr          : ISO20022.Auth038001.InvoiceTaxStatusReportHeader1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validList ("TxSts", TxSts), 
        validElement(TxSts), 
        validElement(StsRptHdr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.038.001.01"), ValidationCheck
value ISO20022.Auth038001.InvoiceTaxReportTransactionStatus1
{
    @XmlElement SplmtryData        : List<ISO20022.Auth038001.SupplementaryData1>,
    @XmlElement VldtnRule          : List<ISO20022.Auth038001.GenericValidationRuleIdentification1>,
    @XmlElement Sts                : String,
