}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validList ("VldtnRule", VldtnRule), 
        validElement(VldtnRule))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.038.001.01"), ValidationCheck
value ISO20022.Auth038001.InvoiceTaxStatusReportHeader1
{
    @XmlElement VldtnRule          : List<ISO20022.Auth038001.GenericValidationRuleIdentification1>,
    @XmlElement RptSts             : String,
    @XmlElement OrgnlMsgId         : ISO20022.Auth038001.MessageIdentification1,
    @XmlElement MsgId              : ISO20022.Auth038001.MessageIdentification1,
    @XmlElement TaxAuthrty         : ISO20022.Auth038001.TaxOrganisationIdentification1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("VldtnRule", VldtnRule), 
