@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:reda.064.001.02"), ValidationCheck
aspect ISO20022.Reda064001.CalendarQueryV02
{
    @XmlElement SplmtryData        : List<ISO20022.Reda064001.SupplementaryData1>,
    @XmlElement SchCrit            : List<ISO20022.Reda064001.CalendarSearchCriteria1>,
    @XmlElement MsgHdr             : ISO20022.Reda064001.MessageHeader9,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validList ("SchCrit", SchCrit), 
        validElement(SchCrit), 
        validElement(MsgHdr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:reda.064.001.02"), ValidationCheck
value ISO20022.Reda064001.CalendarSearchCriteria1
