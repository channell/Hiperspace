@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:reda.064.001.02"), ValidationCheck
value ISO20022.Reda064001.SystemAndCurrency1
{
    @XmlElement SysCcy             : String,
    @XmlElement SysId              : ISO20022.Reda064001.SystemIdentification2Choice,
}
[
