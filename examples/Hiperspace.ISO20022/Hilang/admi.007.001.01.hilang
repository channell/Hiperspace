@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:admi.007.001.01"), ValidationCheck
value ISO20022.Admi007001.NameAndAddress5
{
    @XmlElement Adr                : ISO20022.Admi007001.PostalAddress1,
    @XmlElement Nm                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(Adr))
