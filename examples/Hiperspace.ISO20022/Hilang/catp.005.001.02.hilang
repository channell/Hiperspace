@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:catp.005.001.02"), ValidationCheck
value ISO20022.Catp005001.ATMCommand7
{
    @XmlElement CmdParams          : ISO20022.Catp005001.ATMCommandParameters1Choice,
    @XmlElement CmdId              : ISO20022.Catp005001.ATMCommandIdentification1,
