enum ISO20022.Auth044001.EquityInstrumentReportingClassification1Code
{
    @XmlEnum ("CRFT") CRFT          #1,
    @XmlEnum ("DPRS") DPRS          #2,
    @XmlEnum ("ETFS") ETFS          #3,
    @XmlEnum ("OTHR") OTHR          #4,
    @XmlEnum ("SHRS") SHRS          #5,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.044.001.02"), ValidationCheck
aspect ISO20022.Auth044001.FinancialInstrumentReportingEquityTradingActivityResultV02
{
    @XmlElement SplmtryData        : List<ISO20022.Auth044001.SupplementaryData1>,
    @XmlElement EqtyTrnsprncyData  : List<ISO20022.Auth044001.TransparencyDataReport17>,
    @XmlElement RptHdr             : ISO20022.Auth044001.SecuritiesMarketReportHeader1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validRequired ("EqtyTrnsprncyData", EqtyTrnsprncyData), 
        validList ("EqtyTrnsprncyData", EqtyTrnsprncyData), 
        validElement(EqtyTrnsprncyData), 
        validElement(RptHdr))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.044.001.02"), ValidationCheck
