@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.048.001.01"), ValidationCheck
value ISO20022.Auth048001.CountryCodeAndName3
{
    @XmlElement Nm                 : String,
    @XmlElement Cd                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("Cd", Cd, "[A-Z]{2,2}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.048.001.01"), ValidationCheck
value ISO20022.Auth048001.CurrencyCodeAndName1
{
    @XmlElement Nm                 : String,
    @XmlElement Cd                 : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("Cd", Cd, "[A-Z]{3,3}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.048.001.01"), ValidationCheck
type ISO20022.Auth048001.Document
