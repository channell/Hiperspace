}
[
    @XmlElement FinInstrmRptgCcyCdRpt : ISO20022.Auth048001.FinancialInstrumentReportingCurrencyCodeReportV01,
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(FinInstrmRptgCcyCdRpt))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.048.001.01"), ValidationCheck
aspect ISO20022.Auth048001.FinancialInstrumentReportingCurrencyCodeReportV01
{
    @XmlElement SplmtryData        : List<ISO20022.Auth048001.SupplementaryData1>,
    @XmlElement CcyData            : List<ISO20022.Auth048001.SecuritiesCurrencyIdentification2>,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("SplmtryData", SplmtryData), 
        validElement(SplmtryData), 
        validRequired ("CcyData", CcyData), 
        validList ("CcyData", CcyData), 
        validElement(CcyData))
];

