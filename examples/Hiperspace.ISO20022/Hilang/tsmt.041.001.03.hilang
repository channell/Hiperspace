@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.041.001.03"), ValidationCheck
value ISO20022.Tsmt041001.PostalAddress5
{
    @XmlElement Ctry               : String,
    @XmlElement CtrySubDvsn        : String,
    @XmlElement TwnNm              : String,
    @XmlElement PstCdId            : String,
