}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("Ctry", Ctry, "[A-Z]{2,2}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.041.001.03"), ValidationCheck
value ISO20022.Tsmt041001.TransactionReportItems3
{
    @XmlElement PdgReqForActn      : List<ISO20022.Tsmt041001.PendingActivity2>,
    @XmlElement TtlNetAmt          : ISO20022.Tsmt041001.CurrencyAndAmount,
    @XmlElement OutsdngAmt         : ISO20022.Tsmt041001.CurrencyAndAmount,
    @XmlElement SubmitgBk          : List<ISO20022.Tsmt041001.BICIdentification1>,
    @XmlElement OblgrBk            : List<ISO20022.Tsmt041001.BICIdentification1>,
    @XmlElement SellrBkCtry        : String,
    @XmlElement SellrBk            : ISO20022.Tsmt041001.BICIdentification1,
    @XmlElement BuyrBkCtry         : String,
    @XmlElement BuyrBk             : ISO20022.Tsmt041001.BICIdentification1,
    @XmlElement Sellr              : ISO20022.Tsmt041001.PartyIdentification26,
    @XmlElement Buyr               : ISO20022.Tsmt041001.PartyIdentification26,
    @XmlElement PurchsOrdrRef      : ISO20022.Tsmt041001.DocumentIdentification7,
    @XmlElement UsrTxRef           : List<ISO20022.Tsmt041001.DocumentIdentification5>,
    @XmlElement TxSts              : ISO20022.Tsmt041001.TransactionStatus4,
    @XmlElement EstblishdBaselnId  : ISO20022.Tsmt041001.DocumentIdentification3,
    @XmlElement TxId               : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("PdgReqForActn", PdgReqForActn), 
        validElement(PdgReqForActn), 
        validElement(TtlNetAmt), 
        validElement(OutsdngAmt), 
        validList ("SubmitgBk", SubmitgBk), 
        validElement(SubmitgBk), 
        validList ("OblgrBk", OblgrBk), 
        validElement(OblgrBk), 
        validPattern ("SellrBkCtry", SellrBkCtry, "[A-Z]{2,2}"), 
        validElement(SellrBk), 
        validPattern ("BuyrBkCtry", BuyrBkCtry, "[A-Z]{2,2}"), 
        validElement(BuyrBk), 
        validElement(Sellr), 
        validElement(Buyr), 
        validElement(PurchsOrdrRef), 
        validList ("UsrTxRef", UsrTxRef), 
        validListMax ("UsrTxRef", UsrTxRef, 2), 
        validElement(UsrTxRef), 
        validElement(TxSts), 
        validElement(EstblishdBaselnId))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.041.001.03"), ValidationCheck
aspect ISO20022.Tsmt041001.TransactionReportV03
{
    @XmlElement RptdItms           : List<ISO20022.Tsmt041001.TransactionReportItems3>,
    @XmlElement RltdMsgRef         : ISO20022.Tsmt041001.MessageIdentification1,
    @XmlElement RptId              : ISO20022.Tsmt041001.MessageIdentification1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("RptdItms", RptdItms), 
        validElement(RptdItms), 
        validElement(RltdMsgRef), 
        validElement(RptId))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.041.001.03"), ValidationCheck
value ISO20022.Tsmt041001.TransactionStatus4
{
    @XmlElement Sts                : String,
}
[
    @XmlIgnore, JsonIgnore Validation = ""
];
