%json;
%xml;
%markdown;


@XmlNameSpace("urn:iso:std:iso:20022:tech:xsd:tsmt.010.001.03")
enum ISO20022.Tsmt010001.Action2Code
{
    @XmlEnum ("CINR") CINR          #1,
    @XmlEnum ("ARRO") ARRO          #2,
    @XmlEnum ("ARBA") ARBA          #3,
    @XmlEnum ("SBDS") SBDS          #4,
    @XmlEnum ("UPDT") UPDT          #5,
    @XmlEnum ("WAIT") WAIT          #6,
    @XmlEnum ("ARES") ARES          #7,
    @XmlEnum ("ARCS") ARCS          #8,
    @XmlEnum ("ARDM") ARDM          #9,
    @XmlEnum ("RSBS") RSBS          #10,
    @XmlEnum ("RSTW") RSTW          #11,
    @XmlEnum ("SBTW") SBTW          #12,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.010.001.03"), ValidationCheck
value ISO20022.Tsmt010001.BICIdentification1
{
    @XmlElement BIC                : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("BIC", BIC, "[A-Z]{6,6}[A-Z2-9][A-NP-Z0-9]([A-Z0-9]{3,3}){0,1}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.010.001.03"), ValidationCheck
aspect ISO20022.Tsmt010001.BaselineMatchReportV03
{
    @XmlElement ReqForActn         : ISO20022.Tsmt010001.PendingActivity2,
    @XmlElement Rpt                : ISO20022.Tsmt010001.MisMatchReport3,
    @XmlElement CmpardDocRef       : List<ISO20022.Tsmt010001.DocumentIdentification4>,
    @XmlElement BaselnEstblishmtTrils : ISO20022.Tsmt010001.Limit1,
    @XmlElement SellrBk            : ISO20022.Tsmt010001.BICIdentification1,
    @XmlElement BuyrBk             : ISO20022.Tsmt010001.BICIdentification1,
    @XmlElement Sellr              : ISO20022.Tsmt010001.PartyIdentification26,
    @XmlElement Buyr               : ISO20022.Tsmt010001.PartyIdentification26,
    @XmlElement UsrTxRef           : List<ISO20022.Tsmt010001.DocumentIdentification5>,
    @XmlElement TxSts              : ISO20022.Tsmt010001.TransactionStatus4,
    @XmlElement EstblishdBaselnId  : ISO20022.Tsmt010001.DocumentIdentification3,
    @XmlElement TxId               : ISO20022.Tsmt010001.SimpleIdentificationInformation,
    @XmlElement RptId              : ISO20022.Tsmt010001.MessageIdentification1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(ReqForActn), 
        validElement(Rpt), 
        validList ("CmpardDocRef", CmpardDocRef), 
        validListMin ("CmpardDocRef", CmpardDocRef, 2), 
        validListMax ("CmpardDocRef", CmpardDocRef, 2), 
        validElement(CmpardDocRef), 
        validElement(BaselnEstblishmtTrils), 
        validElement(SellrBk), 
        validElement(BuyrBk), 
        validElement(Sellr), 
        validElement(Buyr), 
        validList ("UsrTxRef", UsrTxRef), 
        validListMax ("UsrTxRef", UsrTxRef, 2), 
        validElement(UsrTxRef), 
        validElement(TxSts), 
        validElement(EstblishdBaselnId), 
        validElement(TxId), 
        validElement(RptId))
];

@XmlNameSpace("urn:iso:std:iso:20022:tech:xsd:tsmt.010.001.03")
enum ISO20022.Tsmt010001.BaselineStatus3Code
