    @XmlEnum ("CLRQ") CLRQ          #4,
    @XmlEnum ("RARQ") RARQ          #5,
    @XmlEnum ("AMRQ") AMRQ          #6,
    @XmlEnum ("COMP") COMP          #7,
    @XmlEnum ("ACTV") ACTV          #8,
    @XmlEnum ("ESTD") ESTD          #9,
    @XmlEnum ("PMTC") PMTC          #10,
    @XmlEnum ("CLSD") CLSD          #11,
    @XmlEnum ("PROP") PROP          #12,
};
@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:tsmt.010.001.03"), ValidationCheck
type ISO20022.Tsmt010001.Document
{
}
[
    @XmlElement BaselnMtchRpt      : ISO20022.Tsmt010001.BaselineMatchReportV03,
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(BaselnMtchRpt))
];

