@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:sese.008.001.09"), ValidationCheck
aspect ISO20022.Sese008001.ReversalOfTransferInConfirmationV09
{
    @XmlElement CpyDtls            : ISO20022.Sese008001.CopyInformation5,
    @XmlElement MktPrctcVrsn       : ISO20022.Sese008001.MarketPracticeVersion1,
    @XmlElement RvslRefs           : List<ISO20022.Sese008001.TransferReference16>,
    @XmlElement Fctn               : String,
    @XmlElement MstrRef            : String,
    @XmlElement RltdRef            : ISO20022.Sese008001.AdditionalReference10,
    @XmlElement PrvsRef            : ISO20022.Sese008001.AdditionalReference10,
    @XmlElement PoolRef            : ISO20022.Sese008001.AdditionalReference11,
    @XmlElement MsgId              : ISO20022.Sese008001.MessageIdentification1,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(CpyDtls), 
        validElement(MktPrctcVrsn), 
        validRequired ("RvslRefs", RvslRefs), 
        validList ("RvslRefs", RvslRefs), 
        validElement(RvslRefs), 
        validElement(RltdRef), 
        validElement(PrvsRef), 
        validElement(PoolRef), 
        validElement(MsgId))
];

