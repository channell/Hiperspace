@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:sese.008.001.09"), ValidationCheck, AnyKey
value ISO20022.Sese008001.PartyIdentification125Choice
{
    @XmlElement NmAndAdr           : ISO20022.Sese008001.NameAndAddress5,
    @XmlElement PrtryId            : ISO20022.Sese008001.GenericIdentification1,
    @XmlElement AnyBIC             : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(NmAndAdr), 
        validElement(PrtryId), 
        validPattern ("AnyBIC", AnyBIC, "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}"), 
        validChoice (NmAndAdr, PrtryId, AnyBIC))
];

