@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:catm.005.001.11"), ValidationCheck
value ISO20022.Catm005001.Vehicle1
{
    @XmlElement AddtlVhclData      : List<ISO20022.Catm005001.Vehicle2>,
    @XmlElement DrvrOrVhclCard     : ISO20022.Catm005001.PlainCardData17,
    @XmlElement MntncId            : String,
    @XmlElement RefrHrs            : String,
    @XmlElement TrlrHrs            : String,
    @XmlElement Hbmtr              : Decimal,
    @XmlElement Odmtr              : Decimal,
    @XmlElement RplcmntCar         : String,
    @XmlElement UnitNb             : String,
    @XmlElement VhclTagNtryMd      : String,
    @XmlElement VhclTag            : String,
    @XmlElement TrlrNb             : String,
    @XmlElement VhclNb             : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validList ("AddtlVhclData", AddtlVhclData), 
        validElement(AddtlVhclData), 
        validElement(DrvrOrVhclCard), 
        validPattern ("UnitNb", UnitNb, "[0-9]{1,35}"), 
        validPattern ("TrlrNb", TrlrNb, "[0-9]{1,35}"), 
        validPattern ("VhclNb", VhclNb, "[0-9]{1,35}"))
];

