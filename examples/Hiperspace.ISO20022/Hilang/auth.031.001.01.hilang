@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.031.001.01"), ValidationCheck
value ISO20022.Auth031001.NumberOfRecordsPerStatus1
{
    @XmlElement DtldSts            : String,
    @XmlElement DtldNbOfRcrds      : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validPattern ("DtldNbOfRcrds", DtldNbOfRcrds, "[0-9]{1,15}"))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.031.001.01"), ValidationCheck
value ISO20022.Auth031001.OriginalReportStatistics3
{
    @XmlElement NbOfRcrdsPerSts    : List<ISO20022.Auth031001.NumberOfRecordsPerStatus1>,
    @XmlElement TtlNbOfRcrds       : String,
}
[
    @XmlIgnore, JsonIgnore Validation = validation (
        validRequired ("NbOfRcrdsPerSts", NbOfRcrdsPerSts), 
        validList ("NbOfRcrdsPerSts", NbOfRcrdsPerSts), 
        validElement(NbOfRcrdsPerSts), 
        validPattern ("TtlNbOfRcrds", TtlNbOfRcrds, "[0-9]{1,15}"))
];

