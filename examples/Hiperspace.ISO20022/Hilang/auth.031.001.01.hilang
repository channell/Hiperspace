    @XmlIgnore, JsonIgnore Validation = validation (
        validElement(FinInstrmRptgStsAdvc))
];

@XmlNameSpace ("urn:iso:std:iso:20022:tech:xsd:auth.031.001.01"), ValidationCheck
aspect ISO20022.Auth031001.FinancialInstrumentReportingStatusAdviceV01
{
    @XmlElement SplmtryData        : List<ISO20022.Auth031001.SupplementaryData1>,
    @XmlElement StsAdvc            : List<ISO20022.Auth031001.MessageReportHeader4>,
}
